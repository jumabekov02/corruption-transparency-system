# Copy this file to ".env" (same folder) and adjust if needed.
# docker-compose reads .env automatically.

# --- PostgreSQL ---
POSTGRES_USER=procurement
POSTGRES_PASSWORD=procurement
POSTGRES_DB=procurement

# --- Backend ---
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- JWT (generate a real secret with: python -c "import secrets;print(secrets.token_hex(32))") ---
JWT_SECRET_KEY=dev-only-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
